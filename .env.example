# Supabase: Dashboard → Project Settings → API, or open the project "Connect" panel.
# Use the Project URL and the public client key (legacy "anon" or new publishable key).
# Never put the service_role secret or any "secret" key here — those belong only on servers.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key_here
